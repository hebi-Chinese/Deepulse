{
  "name": "@deepulse/infrastructure",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./brain": "./src/brain/index.ts",
    "./ncm": "./src/ncm/index.ts",
    "./ncm-client": "./src/ncm/index.ts",
    "./tts": "./src/tts/index.ts",
    "./calendar": "./src/calendar/index.ts",
    "./signal": "./src/signal/index.ts",
    "./db": "./src/db/index.ts",
    "./user-prefs": "./src/user-prefs/index.ts",
    "./clock": "./src/clock/index.ts",
    "./short-term-memory": "./src/short-term-memory/index.ts",
    "./long-term-memory": "./src/long-term-memory/index.ts"
  },
  "scripts": {
    "dev": "tsc -b --watch",
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@deepulse/application": "workspace:*",
    "@deepulse/domain": "workspace:*",
    "@deepulse/shared": "workspace:*",
    "NeteaseCloudMusicApi": "catalog:",
    "better-sqlite3": "catalog:",
    "drizzle-orm": "catalog:",
    "execa": "catalog:",
    "ioredis": "catalog:",
    "undici": "catalog:",
    "zod": "catalog:",
    "zod-to-json-schema": "catalog:"
  },
  "devDependencies": {
    "@deepulse/configs": "workspace:*",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
