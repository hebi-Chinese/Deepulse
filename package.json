{
  "name": "deepulse",
  "version": "0.1.0",
  "private": true,
  "description": "个人 AI 电台 · LLM DJ 大脑 + 网易云音乐 + VoxCPM/SoVITS 语音",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yaml,yml}\"",
    "arch:check": "pnpm --filter @deepulse/arch-test run check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
